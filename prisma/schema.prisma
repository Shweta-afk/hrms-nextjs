generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── CORE TENANT ───────────────────────────────────────

model Organisation {
  id          String   @id @default(uuid())
  name        String
  subdomain   String   @unique
  plan        String   @default("starter")
  settings    Json     @default("{}")
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  users              User[]
  employees          Employee[]
  departments        Department[]
  designations       Designation[]
  leave_types        LeaveType[]
  leave_requests     LeaveRequest[]
  attendance_records AttendanceRecord[]
  payroll_runs       PayrollRun[]
  payslips           Payslip[]
  salary_structures  SalaryStructure[]
  job_postings       JobPosting[]
  candidates         Candidate[]
  notifications      Notification[]
  holidays           Holiday[]
  devices            Device[]
  punch_logs         PunchLog[]
  device_enrollments DeviceEnrollment[]
  api_keys           OrgApiKey[]

  @@map("organisations")
}

// ─── AUTH ───────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  org_id      String
  employee_id String?  @unique
  email       String   @unique
  password    String
  role        String   @default("employee")
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  reset_token          String?
  reset_token_expiry   DateTime?

  // Email verification — null until the user clicks the verification link.
  // `authorize()` in NextAuth refuses to issue a session for users where this is null.
  email_verified_at         DateTime?
  email_verification_token  String?   @unique
  email_verification_expiry DateTime?

  organisation    Organisation   @relation(fields: [org_id], references: [id])
  employee        Employee?      @relation(fields: [employee_id], references: [id])
  notifications   Notification[]
  approved_leaves LeaveRequest[] @relation("ApprovedBy")
  sessions        Session[]

  @@map("users")
}

model Session {
  id            String   @id @default(uuid())
  user_id       String
  session_token String   @unique
  expires       DateTime
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── EMPLOYEES ──────────────────────────────────────────

model Department {
  id         String   @id @default(uuid())
  org_id     String
  name       String
  code       String
  created_at DateTime @default(now())

  organisation Organisation @relation(fields: [org_id], references: [id])
  employees    Employee[]

  @@map("departments")
}

model Designation {
  id         String   @id @default(uuid())
  org_id     String
  name       String
  level      Int      @default(1)
  created_at DateTime @default(now())

  organisation Organisation @relation(fields: [org_id], references: [id])
  employees    Employee[]

  @@map("designations")
}

model Employee {
  id                  String   @id @default(uuid())
  org_id              String
  emp_code            String
  first_name          String
  last_name           String
  email               String
  phone               String?
  department_id       String?
  designation_id      String?
  manager_id          String?
  date_of_joining     DateTime
  employment_type     String   @default("full_time")
  ctc_annual          Decimal? @db.Decimal(12, 2)
  salary_structure_id String?
  salary_structure    SalaryStructure? @relation("EmployeeSalaryStructure", fields: [salary_structure_id], references: [id])
  status              String   @default("active")
  personal_info       Json     @default("{}")
  contact_info        Json     @default("{}")
  bank_details        String?  // encrypted
  statutory_info      String?  // encrypted
  essl_device_id      String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  plan                     String  @default("starter")
  plan_employee_limit      Int     @default(25)
  razorpay_customer_id     String?
  razorpay_subscription_id String?
  subscription_status      String  @default("active")
  trial_ends_at            DateTime?
  billing_email            String?

  organisation       Organisation       @relation(fields: [org_id], references: [id])
  department         Department?        @relation(fields: [department_id], references: [id])
  designation        Designation?       @relation(fields: [designation_id], references: [id])
  manager            Employee?          @relation("ManagerReports", fields: [manager_id], references: [id])
  reports            Employee[]         @relation("ManagerReports")
  user               User?
  attendance         AttendanceRecord[]
  leave_requests     LeaveRequest[]
  payslips           Payslip[]
  device_enrollments DeviceEnrollment[]

  @@unique([org_id, emp_code])
  @@unique([org_id, email])
  @@map("employees")
}

// ─── ATTENDANCE ─────────────────────────────────────────

model AttendanceRecord {
  id                String    @id @default(uuid())
  org_id            String
  employee_id       String
  date              DateTime  @db.Date
  first_in          DateTime?
  last_out          DateTime?
  total_hours       Decimal?  @db.Decimal(4, 2)
  status            String    @default("absent")
  is_late           Boolean   @default(false)
  late_by_minutes   Int       @default(0)
  overtime_hours    Decimal?  @db.Decimal(4, 2)
  is_corrected      Boolean   @default(false)
  correction_reason String?
  source            String    @default("essl")
  device_id         String?
  device_name       String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  organisation Organisation @relation(fields: [org_id], references: [id])
  employee     Employee     @relation(fields: [employee_id], references: [id])

  @@unique([org_id, employee_id, date])
  // Hot path: cron job + live attendance dashboard query `WHERE org_id = ? AND date = ?`
  // Covers both ascending and descending scans within an org.
  @@index([org_id, date])
  @@map("attendance_records")
}

// ─── DEVICE INTEGRATION ─────────────────────────────────

model Device {
  id             String    @id @default(uuid())
  org_id         String
  name           String
  model          String?                      // e.g. "AIFACE Magnum", "ZK400", etc.
  ip_address     String
  port           Int       @default(4370)
  serial_no      String?
  location       String?
  timezone       String    @default("Asia/Kolkata")  // IANA tz — used to parse device push times
  push_token     String    @unique @default(uuid())
  is_active      Boolean   @default(true)
  last_heartbeat DateTime?
  last_sync      DateTime?
  total_punches  Int       @default(0)
  status         String    @default("offline")
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  organisation       Organisation       @relation(fields: [org_id], references: [id])
  punch_logs         PunchLog[]
  device_enrollments DeviceEnrollment[]

  @@map("devices")
}

model PunchLog {
  id         String   @id @default(uuid())
  org_id     String
  device_id  String
  emp_code   String
  punch_time DateTime
  direction  String   // IN or OUT
  raw_data   String?
  processed  Boolean  @default(false)
  created_at DateTime @default(now())

  organisation Organisation @relation(fields: [org_id], references: [id])
  device       Device       @relation(fields: [device_id], references: [id])

  // Hot path: punch-processor scans `WHERE org_id = ? AND processed = false`
  @@index([org_id, processed])
  // Live attendance feed orders by punch_time desc
  @@index([org_id, punch_time(sort: Desc)])
  @@map("punch_logs")
}

model DeviceEnrollment {
  id          String    @id @default(uuid())
  org_id      String
  device_id   String
  employee_id String
  status      String    @default("pending") // pending, enrolled, failed
  synced_at   DateTime?
  enrolled_at DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  organisation Organisation @relation(fields: [org_id], references: [id])
  device       Device       @relation(fields: [device_id], references: [id])
  employee     Employee     @relation(fields: [employee_id], references: [id])

  @@unique([device_id, employee_id])
  @@map("device_enrollments")
}

// ─── LEAVE ──────────────────────────────────────────────

model LeaveType {
  id                  String   @id @default(uuid())
  org_id              String
  name                String
  code                String
  days_per_year       Decimal  @db.Decimal(5, 1)
  carry_forward_limit Int      @default(0)
  is_paid             Boolean  @default(true)
  applicable_gender   String   @default("all")
  min_notice_days     Int      @default(0)
  created_at          DateTime @default(now())

  organisation   Organisation   @relation(fields: [org_id], references: [id])
  leave_requests LeaveRequest[]

  @@map("leave_types")
}

model LeaveRequest {
  id               String    @id @default(uuid())
  org_id           String
  employee_id      String
  leave_type_id    String
  from_date        DateTime  @db.Date
  to_date          DateTime  @db.Date
  total_days       Decimal   @db.Decimal(4, 1)
  status           String    @default("pending")
  reason           String
  approved_by      String?
  approved_at      DateTime?
  rejection_reason String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  organisation Organisation @relation(fields: [org_id], references: [id])
  employee     Employee     @relation(fields: [employee_id], references: [id])
  leave_type   LeaveType    @relation(fields: [leave_type_id], references: [id])
  approver     User?        @relation("ApprovedBy", fields: [approved_by], references: [id])

  // Hot path: HR approval queue filters `WHERE org_id = ? AND status = 'pending'`
  @@index([org_id, status])
  @@index([employee_id, status])
  @@map("leave_requests")
}

model Holiday {
  id         String   @id @default(uuid())
  org_id     String
  name       String
  date       DateTime @db.Date
  type       String   @default("national")
  created_at DateTime @default(now())

  organisation Organisation @relation(fields: [org_id], references: [id])

  @@map("holidays")
}

// ─── PAYROLL ────────────────────────────────────────────

model PayrollRun {
  id               String    @id @default(uuid())
  org_id           String
  month            Int
  year             Int
  status           String    @default("draft")
  total_gross      Decimal   @db.Decimal(12, 2) @default(0)
  total_deductions Decimal   @db.Decimal(12, 2) @default(0)
  total_net        Decimal   @db.Decimal(12, 2) @default(0)
  run_by           String?
  approved_by      String?
  paid_at          DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  organisation Organisation @relation(fields: [org_id], references: [id])
  payslips     Payslip[]

  @@unique([org_id, month, year])
  @@map("payroll_runs")
}

model Payslip {
  id               String   @id @default(uuid())
  org_id           String
  employee_id      String
  payroll_run_id   String
  month            Int
  year             Int
  working_days     Int
  present_days     Decimal  @db.Decimal(4, 1)
  earnings         Json
  deductions       Json
  gross_salary     Decimal  @db.Decimal(10, 2)
  total_deductions Decimal  @db.Decimal(10, 2)
  net_salary       Decimal  @db.Decimal(10, 2)
  pdf_s3_key       String?
  is_published     Boolean  @default(false)
  created_at       DateTime @default(now())

  organisation Organisation @relation(fields: [org_id], references: [id])
  employee     Employee     @relation(fields: [employee_id], references: [id])
  payroll_run  PayrollRun   @relation(fields: [payroll_run_id], references: [id])

  @@unique([org_id, employee_id, month, year])
  @@map("payslips")
}

// ─── RECRUITMENT ────────────────────────────────────────

model JobPosting {
  id          String   @id @default(uuid())
  org_id      String
  title       String
  department  String
  location    String
  openings    Int      @default(1)
  description String
  status      String   @default("open")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  organisation Organisation @relation(fields: [org_id], references: [id])
  candidates   Candidate[]

  @@map("job_postings")
}

model Candidate {
  id               String   @id @default(uuid())
  org_id           String
  job_posting_id   String
  name             String
  email            String
  phone            String?
  resume_url       String?
  current_company  String?
  experience_years Int?
  stage            String   @default("applied")
  ai_score         Int?
  ai_summary       String?
  source           String   @default("website")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  job_posting  JobPosting   @relation(fields: [job_posting_id], references: [id])
  organisation Organisation @relation(fields: [org_id], references: [id])

  @@index([org_id, stage])
  @@map("candidates")
}

// ─── NOTIFICATIONS ──────────────────────────────────────

model Notification {
  id         String   @id @default(uuid())
  org_id     String
  user_id    String
  title      String
  message    String
  type       String   @default("info")
  is_read    Boolean  @default(false)
  link       String?
  created_at DateTime @default(now())

  organisation Organisation @relation(fields: [org_id], references: [id])
  user         User         @relation(fields: [user_id], references: [id])

  // Hot path: nav badge polls `WHERE user_id = ? AND is_read = false`
  @@index([user_id, is_read])
  // List view orders by created_at desc per user
  @@index([user_id, created_at(sort: Desc)])
  @@map("notifications")
}

model SalaryStructure {
  id          String   @id @default(uuid())
  org_id      String
  name        String
  description String?
  components  Json
  is_default  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  organisation Organisation @relation(fields: [org_id], references: [id])
  employees    Employee[]   @relation("EmployeeSalaryStructure")

  @@map("salary_structures")
}

// ─── RATE LIMIT (shared store for serverless) ──────────────────────────
// Replaces the in-memory Map that doesn't survive across lambda invocations.
// Key shape: "<bucket>:<identifier>" e.g. "login:1.2.3.4" or "signup:1.2.3.4"
// The same window/cap config lives in the call sites; this table only tracks
// the count and the wall-clock expiry. Cleared by anything past `expires_at`.
model RateLimitEntry {
  key        String   @id
  count      Int      @default(0)
  expires_at DateTime
  updated_at DateTime @updatedAt

  @@index([expires_at])
  @@map("rate_limit_entries")
}

// ─── API KEYS ────────────────────────────────────────────

model OrgApiKey {
  id         String    @id @default(uuid())
  org_id     String
  name       String
  key_hash   String    @unique  // SHA-256 of the raw key — never store plaintext
  last_used  DateTime?
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())

  organisation Organisation @relation(fields: [org_id], references: [id])

  @@map("org_api_keys")
}
